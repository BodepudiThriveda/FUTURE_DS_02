      <column caption='churn rate' datatype='real' name='[Calculation_0613843206803456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Churn] = &quot;Yes&quot; THEN 1 END) &#13;&#10;/ &#13;&#10;COUNT([customerID])' />
